# OpenAI API 金鑰（用於 Whisper 語音轉文字）
OPENAI_API_KEY=

# GitLab Webhook 驗證密鑰
GITLAB_WEBHOOK_SECRET=

# Google OAuth 憑證檔案路徑
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Telegram Bot Token（用於語音日誌收集）
TELEGRAM_BOT_TOKEN=

# Qdrant 向量資料庫 URL
QDRANT_URL=http://localhost:6333

# PostgreSQL 連線字串 (使用 asyncpg 驅動程式)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pro_copilot
