{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pro-copilot.local/schemas/harness-task.json",
  "title": "AI development harness task",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "task", "phase", "phase_history", "requirements", "design", "plan", "changes", "verification", "review", "open_items"],
  "properties": {
    "version": {"const": 1},
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1}
      }
    },
    "phase": {
      "enum": ["intake", "design", "plan", "implement", "verify", "review", "done", "blocked"]
    },
    "phase_history": {
      "type": "array",
      "minItems": 1,
      "items": {"enum": ["intake", "design", "plan", "implement", "verify", "review", "done", "blocked"]}
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request", "assumptions", "success_criteria", "constraints", "out_of_scope"],
      "properties": {
        "request": {"type": "string", "minLength": 1},
        "assumptions": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "success_criteria": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "constraints": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "out_of_scope": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "design": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approach", "alternatives", "risks"],
      "properties": {
        "approach": {"type": "string"},
        "alternatives": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "risks": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "plan": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "changes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "summary"],
      "properties": {
        "files": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "summary": {"type": "string"}
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "result", "status"],
        "properties": {
          "command": {"type": "string", "minLength": 1},
          "result": {"type": "string", "minLength": 1},
          "status": {"enum": ["pass", "fail", "not_run"]}
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "notes"],
      "properties": {
        "status": {"enum": ["pending", "pass", "fail"]},
        "notes": {"type": "string"}
      }
    },
    "open_items": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
